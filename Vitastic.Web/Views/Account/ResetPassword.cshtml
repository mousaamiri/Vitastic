@model Vitastic.Web.Models.ViewModels.ResetPasswordUserModel

@{
    ViewData["CourseTitle"] = "بازنشانی رمز عبور";
    Layout = "_Layout";
}

<!-- Page CourseTitle -->
<div class="page-title light-background">
    <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">بازنشانی رمز عبور</h1>
        <nav class="breadcrumbs">
            <ol>
                <li><a class="ajax-link" href="/">خانه</a></li>
                <li class="current">بازنشانی رمز عبور</li>
            </ol>
        </nav>
    </div>
</div><!-- End Page CourseTitle -->

<!-- Reset Password Section -->
<section id="reset-password" class="enroll section mt-0 mb-5">
    <div class="container" @* data-aos="fade-up" data-aos-delay="100" *@>

        <div class="row">
            <div class="col-lg-8 mx-auto">
	            <div class="enrollment-form-wrapper">
                    
		            @if (ViewBag.IsSuccess != null && ViewBag.IsSuccess == true)
		            {
			            <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
				            <strong>موفقیت!</strong> رمز عبور شما با موفقیت بازنشانی شد. اکنون می‌توانید وارد شوید.
				            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
			            </div>
			            <h2>بازنشانی موفق</h2>
			            <p>تبریک! رمز عبور شما با موفقیت تغییر کرد. به زودی به صفحه ورود هدایت خواهید شد.</p>
			            <script>
                            const loginUrl = '@Url.Action("Login", "Account")';
				            setTimeout(function() {
                                window.location.href = loginUrl;
				            }, 2000); // Redirect after 2 seconds
			            </script>
		            }
		            else if (ViewBag.IsSuccess != null && ViewBag.IsSuccess == false)
		            {
			            <div class="alert alert-danger alert-dismissible fade show text-center" role="alert">
				            <strong>خطا!</strong> مشکلی در بازنشانی رمز عبور رخ داد. لطفاً دوباره تلاش کنید یا با پشتیبانی تماس بگیرید.
				            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
			            </div>
		            }
		            <div class="enrollment-header text-center" @* data-aos="fade-up" data-aos-delay="200" *@>
			            <h2>بازنشانی رمز عبور</h2>
			            <p>رمز عبور جدید خود را وارد کنید تا حساب کاربری خود را بازیابی کنید.</p>
		            </div>

                <form id="reset-password-form" class="enrollment-form needs-validation was-validated"
                          novalidate asp-action="ResetPassword" asp-controller="Account" method="post"
                      @* data-aos="fade-up" data-aos-delay="300" *@>

                  <div asp-validation-summary="All" class="text-danger"></div>
                  <input asp-for="Token" value="@Model.Token" type="hidden"/>
                  <div class="row mb-4">
                    <div class="col-md-6 mb-3">
                      <div class="form-group mb-2 position-relative">
                        <label class="form-label">رمز عبور *</label>
                        <input type="password"
                               required
                               asp-for="NewPassword"
                               pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&])[A-Za-z\d@@$!%*?&]{6,20}$"
                               class="form-control" autocomplete="new-password">
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                        <!-- Tooltip -->
                        <div class="invalid-tooltip">رمز عبور را وارد کنید.</div>
                        <div class="valid-tooltip">👌</div>
                      </div>
                    </div>
                    <div class="col-md-6 mt-2">
                      <div class="form-group mb-2 position-relative">
                        <label
                               class="form-label">تکرار رمز عبور *</label>
                        <input
                          asp-for="ConfirmPassword"
                          type="password"
                          required
                          pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&])[A-Za-z\d@@$!%*?&]{6,20}$"
                          class="form-control" autocomplete="new-password">
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        <!-- Tooltip -->
                        <div class="invalid-tooltip">تکرار رمز عبور الزامی است.</div>
                        <div class="valid-tooltip">👌</div>
                      </div>
                    </div>
                  </div>

                  <div class="row">
                    <div class="col-12 text-center">
                      <button id="reset-password-form-submit-button" type="submit" class="btn btn-enroll">
                        <i class="bi bi-lock-fill me-2"></i>
                        بازنشانی رمز عبور
                      </button>
                      <p class="enrollment-note mt-3">
                        <i class="bi bi-shield-check"></i>
                        اطلاعات شما امن است و هرگز با اشخاص ثالث به اشتراک گذاشته نخواهد شد
                      </p>
                      <p class="mt-3">
                        حساب کاربری ندارید؟ <a href="/Register" class="text-primary ajax-link">ثبت‌نام کنید</a>
                      </p>
                      <p class="mt-2">
                        به خاطر آوردید؟ <a href="/Login" class="text-primary ajax-link">وارد شوید</a>
                      </p>
                    </div>
                  </div>
                </form>
	            </div>
            </div><!-- End Form Column -->
        </div>
    </div>
</section><!-- /Reset Password Section -->
<script src="~/public/js/custom/password-with-confirmation-validation-resetpass.js"></script>
<script>
  "use strict";
  const regForm = document.getElementById('reset-password-form');
  const registerFormSubmitButton = document.getElementById('reset-password-form-submit-button');
  registerFormSubmitButton.disabled = true;
  regForm.addEventListener("input", () => {
    if (regForm.checkValidity()) {
      registerFormSubmitButton.disabled = false;
    } else {
      registerFormSubmitButton.disabled = true;
    }
  });

  regForm.addEventListener("submit", (e) => {
    if (!regForm.checkValidity()) {
      e.preventDefault();
    }
  });
</script>


