 @model Vitastic.Web.Models.ViewModels.ForgetPasswordUserModel

@{
    ViewData["CourseTitle"] = "بازیابی رمز عبور";
    Layout = "_Layout";
}

<!-- Page CourseTitle -->
<div class="page-title light-background">
    <div class="container ">
        <nav class="breadcrumbs">
            <ol>
                <li><a class="ajax-link" href="/">خانه</a></li>
                <li class="current">بازیابی رمز عبور</li>
            </ol>
        </nav>
        <h1 class="mb-2 mb-lg-0">بازیابی رمز عبور</h1>
    </div>
</div><!-- End Page CourseTitle -->

<!-- Forgot Password Section -->
<section id="forgot-password" class="enroll section mt-0 mb-5">
    <div class="container"  data-aos="fade-up" data-aos-delay="100" >
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="enrollment-form-wrapper">
                    @if (ViewBag.IsSuccess != null && ViewBag.IsSuccess == true)
                    {
                        <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
                            <strong>موفقیت!</strong> لینک بازیابی رمز عبور به ایمیل شما ارسال شد. لطفاً صندوق ورودی یا پوشه اسپم را بررسی کنید.
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
                        </div>
                    } else if (ViewBag.IsSuccess != null && ViewBag.IsSuccess == false)
                    {
	                    <div class="alert alert-danger alert-dismissible fade show text-center" role="alert">
		                    <strong>خطا!</strong> مشکلی در ارسال لینک بازیابی رخ داد. لطفاً دوباره تلاش کنید یا با پشتیبانی تماس بگیرید.
		                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
	                    </div>
                    }

                    <div class="enrollment-header text-center" data-aos="fade-up" data-aos-delay="100" >
                        <h2>بازیابی رمز عبور</h2>
                        <p>آدرس ایمیل خود را وارد کنید تا لینک بازیابی رمز عبور برای شما ارسال شود.</p>
                    </div>

                    <form id="forgot-password-form" class="enrollment-form was-validated" asp-action="ForgotPassword" asp-controller="Account"
                          method="post"  data-aos="fade-up" data-aos-delay="100" >
	                    @Html.AntiForgeryToken()
	                    <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="row mb-4">
                            <div class="form-group mb-2 position-relative">
                                <label for="email-input" class="form-label">ایمیل *</label>
                                <input asp-for="Email" id="email-input" class="pe-5 pt-2 form-control" required/>

                                <!-- ASP.NET Core Validation //For server validation -->
                                <span asp-validation-for="Email" id="email-validation" class="d-none"></span>

                                <!-- Tooltip Bootstrap -->
                                <div class="invalid-tooltip"></div>
                                <div class="valid-tooltip"></div>
                            </div>

                        </div>

                        <div class="row">
                            <div class="col-12 text-center">
                                <button type="submit" id="forgot-password-form-submit-button" class="btn btn-enroll">
                                    <i class="bi bi-envelope me-2" ></i>
                                    ارسال لینک بازیابی
                                </button>
                                <p class="enrollment-note mt-3">
                                    <i class="bi bi-shield-check"></i>
                                    اطلاعات شما امن است و هرگز با اشخاص ثالث به اشتراک گذاشته نخواهد شد
                                </p>
                                <p class="mt-3">
                                    حساب کاربری ندارید؟ <a href="/Register" class="text-primary ajax-link">ثبت‌نام کنید</a>
                                </p>
                                <p class="mt-2">
                                    به خاطر آوردید؟ <a href="/Login" class="text-primary" ajax-link>وارد شوید</a>
                                </p>
                            </div>
                        </div>
                    </form>
                </div>
            </div><!-- End Form Column -->
        </div>
    </div>
</section><!-- /Forgot Password Section -->
<script src="~/public/js/custom/email-validation.js"></script>
<script>
	"use strict";
	const regForm = document.getElementById('forgot-password-form');
	const registerFormSubmitButton = document.getElementById('forgot-password-form-submit-button');
	registerFormSubmitButton.disabled = true;
	regForm.addEventListener("input", () => {
		if (regForm.checkValidity()) {
			registerFormSubmitButton.disabled = false;
		} else {
			registerFormSubmitButton.disabled = true;
		}
	});

	regForm.addEventListener("submit", (e) => {
		if (!regForm.checkValidity()) {
			e.preventDefault();
		}
	});
</script>
