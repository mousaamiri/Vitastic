@model Vitastic.Web.Models.ViewModels.RegisterUserModel

@{
  ViewData["CourseTitle"] = "ثبت نام";
  Layout = "_Layout";
}

<!-- Page CourseTitle -->
<div class="page-title light-background">
  <div class="container ">
    <nav class="breadcrumbs">
      <ol>
        <li><a class="ajax-link" href="/">خانه</a></li>
        <li class="current">ثبت‌نام</li>
      </ol>
    </nav>
    <h1 class="mt-2 mb-lg-0">ثبت‌نام</h1>
  </div>
</div><!-- End Page CourseTitle -->
<!-- Register Section -->
<section id="register" class="enroll section mt-0 mb-4">

  <div class="container" data-aos="fade-up" data-aos-delay="100">

    <div class="row">
      <div class="col-lg-8 mx-auto">
        <div class="enrollment-form-wrapper">
          @if (ViewBag.IsSuccess != null && ViewBag.IsSuccess == true)
          {
            <div class="alert alert-success alert-dismissible fade show text-center" role="alert">
              <strong>موفقیت!</strong> ورود با موفقیت انجام شد.
              <span id="redirectCounter">3</span> ثانیه دیگر به صفحه ورود منتقل می‌شوید...
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
            </div>

            <h2>ورود موفق</h2>
            <p>تبریک! شما با موفقیت وارد حساب کاربری خود شدید. به زودی به صفحه ورود هدایت خواهید شد.</p>

            <script>
              let counter = 3;
              const counterElement = document.getElementById("redirectCounter");

              const interval = setInterval(function () {
                counter--;
                if (counterElement) counterElement.textContent = counter;

                const loginUrl = '@Url.Action("Login", "Account")';

                if (counter <= 0) {
                  clearInterval(interval);
                  window.location.href = loginUrl;
                }
              }, 1000);
            </script>
          }
          <div class="enrollment-header text-center" @* data-aos="fade-up" data-aos-delay="200" *@>
            <h2>ایجاد حساب کاربری</h2>
            <p>برای شروع سفر یادگیری خود به پلتفرم ما بپیوندید. فرم زیر را برای ثبت‌نام پر کنید.</p>
          </div>

          <form id="register-form" class="needs-validation was-validated" novalidate asp-action="Register"
                method="post"
                data-aos="fade-up" data-aos-delay="300">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="row mb-4">
              <div class="form-group mb-2 position-relative">
                <label for="username" class="form-label">نام کاربری *</label>

                <input style="direction: ltr;" type="text" id="username"
                       required
                       asp-for="UserName"
                       name="username" class="form-control pe-5 pt-2" autocomplete="username">
                <!-- Tooltip -->
                <div class="invalid-tooltip"></div>
                <div class="valid-tooltip"></div>
                <span asp-validation-for="UserName" class="text-danger"></span>

              </div>
            </div>

            <div class="row mb-4">
              <div class="form-group mb-2 position-relative">
                <label for="email-input" class="form-label">ایمیل *</label>
                <input
                  asp-for="Email"
                  id="email-input" class="pe-5 pt-2 form-control" required/>

                <!-- ASP.NET Core Validation //For server validation -->
                <span asp-validation-for="Email" class="d-none"></span>

                <!-- Tooltip Bootstrap -->
                <div class="invalid-tooltip"></div>
                <div class="valid-tooltip"></div>
              </div>

            </div>

            <div class="row mb-4">
              <div class="col-md-6 mb-3">
                <div class="form-group mb-2 position-relative">
                  <label for="password" class="form-label">رمز عبور *</label>
                  <input type="password"
                         id="password" name="password"
                         required
                         asp-for="Password"
                         class="form-control" autocomplete="new-password">
                  <span asp-validation-for="Password" class="text-danger"></span>
                  <!-- Tooltip -->
                  <div class="invalid-tooltip">رمز عبور را وارد کنید.</div>
                  <div class="valid-tooltip">👌</div>
                </div>
              </div>
              <div class="col-md-6 mt-2">
                <div class="form-group mb-2 position-relative">
                  <label for="confirmPassword"
                         class="form-label">تکرار رمز عبور *</label>
                  <input
                    asp-for="ConfirmPassword"
                    type="password" id="confirmPassword"
                    required
                    name="confirmPassword" class="form-control" autocomplete="new-password">
                  <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                  <!-- Tooltip -->
                  <div class="invalid-tooltip">تکرار رمز عبور الزامی است.</div>
                  <div class="valid-tooltip">👌</div>
                </div>
              </div>
            </div>

            <div class="row mb-4">
              <div class="col-12">
                <div class="form-group mb-2">
                  <div class="agreement-section">
                    <div class="form-check">
                      <input class="form-check-input"
                             asp-for="AcceptTerms"
                             type="checkbox">
                      <label class="form-check-label" for="terms">
                        با <a href="#">شرایط خدمات</a> و <a href="#">سیاست حفظ حریم خصوصی</a> موافقم *
                      </label>
                      <span asp-validation-for="AcceptTerms" class="text-danger"></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="row">
              <div class="col-12 text-center">
                <button id="register-form-submit-button" type="submit" class="btn btn-enroll">
                  <i class="bi bi-check-circle me-2"></i>
                  ثبت‌نام کنید
                </button>
                <p class="enrollment-note mt-3">
                  <i class="bi bi-shield-check"></i>
                  اطلاعات شما امن است و هرگز با اشخاص ثالث به اشتراک گذاشته نخواهد شد
                </p>
                <p class="mt-3">
                  حساب کاربری دارید؟ <a href="/Login" class="ajax-link text-primary">وارد شوید</a>
                </p>
              </div>
            </div>

          </form>

        </div>
      </div><!-- End Form Column -->

    </div>

  </div>

</section><!-- /Register Section -->
<script src="~/public/js/custom/email-validation.js"></script>
<script src="~/public/js/custom/username-validation.js"></script>
<script src="~/public/js/custom/password-with-confirmation-validation.js"></script>
<script>
  "use strict";
  const regForm = document.getElementById('register-form');
  const registerFormSubmitButton = document.getElementById('register-form-submit-button');
  registerFormSubmitButton.disabled = true;
  regForm.addEventListener("input", () => {
    debugger
    if (regForm.checkValidity()) {
      registerFormSubmitButton.disabled = false;
    } else {
      registerFormSubmitButton.disabled = true;
    }
  });

  regForm.addEventListener("submit", (e) => {
    if (!regForm.checkValidity()) {
      debugger
      e.preventDefault();
    }
  });
</script>
