@{
    ViewData["CourseTitle"] = "فعالسازی حساب کاربری";
    Layout = "_Layout";
}

<!-- Page CourseTitle -->
<div class="page-title light-background">
    <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">فعالسازی حساب کاربری</h1>
        <nav class="breadcrumbs">
            <ol>
                <li><a class="ajax-link" href="/">خانه</a></li>
                <li class="current">فعالسازی حساب کاربری</li>
            </ol>
        </nav>
    </div>
</div><!-- End Page CourseTitle -->
<!-- Activation Section -->
<section id="activation" class="enroll section mt-0 mb-4">
    <div class="container" @* data-aos="fade-up" data-aos-delay="100" *@>
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="enrollment-form-wrapper text-center">
                    <div class="enrollment-header" @* data-aos="fade-up" data-aos-delay="200" *@>
                        @if (ViewBag.IsActive)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <strong>موفقیت!</strong> حساب کاربری شما با موفقیت فعال شد.
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
                            </div>
                            <h2>حساب کاربری شما فعال شد!</h2>
                            <p>تبریک! حساب کاربری شما با موفقیت فعال شده است. اکنون می‌توانید وارد پلتفرم شوید و از امکانات آن استفاده کنید.</p>
                        }
                        else
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong>خطا!</strong> لینک فعالسازی نامعتبر است یا منقضی شده است.
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
                            </div>
                            <h2>خطا در فعالسازی حساب</h2>
                            <p>لطفاً دوباره تلاش کنید یا لینک جدیدی درخواست کنید.</p>
                        }
                    </div>
                    <div class="row">
                        <div class="col-12">
                            @if (ViewBag.IsActive)
                            {
                                <p class="mt-3">
                                    <a href="/Login" class="btn ajax-link btn-enroll">
                                        <i class="bi bi-box-arrow-in-right me-2"></i>
                                        ورود به حساب کاربری
                                    </a>
                                </p>
                            }
                            else
                            {
                                <p class="mt-3">
                                    <a href="/ResendActivation" class="btn ajax-link btn-enroll">
                                        <i class="bi bi-arrow-repeat me-2"></i>
                                        درخواست لینک فعالسازی جدید
                                    </a>
                                </p>
                            }
                            <p class="enrollment-note mt-3">
                                <i class="bi bi-shield-check me-2"></i>
                                اطلاعات شما امن است و هرگز با اشخاص ثالث به اشتراک گذاشته نخواهد شد
                            </p>
                            <p class="mt-3">
                                <a href="/" class="text-primary">بازگشت به صفحه اصلی</a>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section><!-- /Activation Section -->
