@model PaginatedData<Vitastic.Web.Models.DTOs.Instructor.InstructorDto>
<div class="container" data-aos="fade-up" data-aos-delay="100">

  <div class="row gy-4">
  @foreach (var instructor in Model.Items)
  {
    <div class="col-xl-3 col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
      <div class="instructor-card">
        <div class="instructor-image">
          <img src="@instructor.Avatar" class="img-fluid" alt="">
          <div class="overlay-content">
            <div class="rating-stars">
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-half"></i>
              <span>@instructor.AverageRating</span>
            </div>
            <div class="course-count">
              <i class="bi bi-play-circle"></i>
              <span>@instructor.TotalRatings رای داده اند </span>
            </div>
          </div>
        </div>
        <div class="instructor-info">
          <h5>@instructor.FullName</h5>
          <p class="specialty">@instructor.Expertise</p>
          <p class="description">@instructor.Bio </p>
          <div class="stats-grid">
            <div class="stat">
              <span class="number">2.1k</span>
              <span class="label">دانشجویان</span>
            </div>
            <div class="stat">
              <span class="number">@instructor.AverageRating</span>
              <span class="label">امتیاز</span>
            </div>
          </div>
          <div class="action-buttons">
            <a href="#" class="btn-view">مشاهده پروفایل</a>
            <div class="social-links">
              <a href="#"><i class="bi bi-linkedin"></i></a>
              <a href="#"><i class="bi bi-twitter"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  }
  </div>
</div>

