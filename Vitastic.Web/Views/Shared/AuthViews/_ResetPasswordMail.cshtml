@* @model Vitastic.Infrastructure.Entities.User.User *@

@{
    ViewData["Title"] = "بازیابی رمز عبور";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>بازیابی رمز عبور</title>
    <!-- Bootstrap CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <!-- Vazirmatn Font CDN -->
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body, head, * {
            direction: rtl;
        }
        body {
            font-family: 'Vazirmatn', Arial, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0 auto;
        }
        .container {
            max-width: 600px;
            padding: 0 15px;
            margin: 0 auto;
        }
        .card {
            border: 1px solid #dee2e6;
            border-radius: 8px;
            background-color: #fff;
            padding: 20px;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
        }
        .btn-custom {
            background-color: #007bff;
            color: #fff;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            display: inline-block;
        }
        .btn-custom:hover {
            background-color: #0056b3;
        }
        .footer-text {
            font-size: 14px;
            color: #6c757d;
            margin-top: 20px;
            text-align: center;
        }
        .alert {
            margin-bottom: 20px;
        }
        p {
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <div class="header">
                <h2>بازیابی رمز عبور</h2>
                <p>به پلتفرم ویتاستیک خوش آمدید!</p>
            </div>
            <div class="alert alert-success text-center" style="direction: rtl; justify-content: center;" role="alert">
                <strong>موفقیت!</strong> درخواست بازیابی رمز عبور شما دریافت شد.
            </div>
            <p style="text-align: center;">
                یک لینک بازیابی رمز عبور به آدرس ایمیل <strong>@Model.Email</strong> ارسال شده است. لطفاً ایمیل خود را بررسی کنید (شامل پوشه هرزنامه یا اسپم) و روی لینک زیر کلیک کنید تا رمز عبور خود را بازنشانی کنید:
            </p>
            <div style="text-align: center; margin: 20px 0;">
                <a href="https://localhost:7018/Account/ResetPassword/@Model.ActiveCode" class="btn-custom">بازنشانی رمز عبور</a>
            </div>
            <p style="text-align: center;">
                اگر دکمه بالا کار نکرد، لینک زیر را کپی کرده و در مرورگر خود جای‌گذاری کنید:
            </p>
            <p style="text-align: center; word-break: break-all;">
                <a href="https://localhost:7018/Account/ResetPassword/@Model.ActiveCode">https://localhost:7018/Account/ResetPassword/@Model.ActiveCode</a>
            </p>
            <p class="footer-text">
                اگر ایمیل را دریافت نکردید، می‌توانید <a href="https://localhost:7018/ForgotPassword" style="color: #007bff;">درخواست لینک جدید</a> کنید.<br>
                اطلاعات شما امن است و هرگز با اشخاص ثالث به اشتراک گذاشته نخواهد شد.
            </p>
        </div>
    </div>
</body>
</html>