<!-- Courses Hero Section -->
<section id="courses-hero" class="courses-hero section light-background">

	<div class="hero-content">
		<div class="container">
			<div class="row align-items-center">

				<div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
					<div class="hero-text">
						<h1>آینده خود را با دوره‌های آنلاین هدایت‌شده توسط متخصصان متحول کنید</h1>
						<p>هزاران دوره با کیفیت بالا که توسط متخصصان صنعت طراحی شده‌اند را کشف کنید. با سرعت خودتان یاد بگیرید، مهارت‌های مورد تقاضا را کسب کنید و حرفه خود را از هر جای دنیا پیش ببرید.</p>

						<div class="hero-stats">
							<div class="stat-item">
								<span class="number purecounter" data-purecounter-start="0" data-purecounter-end="50000" data-purecounter-duration="2"></span>
								<span class="label">دانشجویان ثبت‌نام‌شده</span>
							</div>
							<div class="stat-item">
								<span class="number purecounter" data-purecounter-start="0" data-purecounter-end="1200" data-purecounter-duration="2"></span>
								<span class="label">دوره‌های تخصصی</span>
							</div>
							<div class="stat-item">
								<span class="number purecounter" data-purecounter-start="0" data-purecounter-end="98" data-purecounter-duration="2"></span>
								<span class="label">نرخ موفقیت %</span>
							</div>
						</div>

						<div class="hero-buttons">
							<a href="#courses" class="btn btn-primary">مرور دوره‌ها</a>
							<a href="#about" class="btn btn-outline">بیشتر بدانید</a>
						</div>

						<div class="hero-features">
							<div class="feature">
								<i class="bi bi-shield-check"></i>
								<span>برنامه‌های معتبر</span>
							</div>
							<div class="feature">
								<i class="bi bi-clock"></i>
								<span>دسترسی مادام‌العمر</span>
