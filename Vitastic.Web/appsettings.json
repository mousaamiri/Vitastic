{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "rollingOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Vitastic.Web"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnectionString": "YOUR_POSTGRESQL_CONNECTION_STRING"
  },
  "FileSettings": {
    "AvatarsDirectoryPath": "wwwroot\\admin-assets\\assets\\img\\avatars\\",
    "DefaultAvatarName": "default.svg",
    "CoursesDirectoryPath": "wwwroot\\img\\education\\courses\\",
    "DefaultCourseImageName": "courses.webp",
    "DefaultCourseThumbnailImageName": "course-thumbnail.png"
  },
  "ApiSettings": {
    "BaseUrl": "http://localhost:10000/api/v1/",
    "TimeoutSeconds": 30
  }
}
