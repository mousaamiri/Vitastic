@model Vitastic.Web.Areas.AdminPanel.Models.Users.UserManagerViewModel
<style>
  .card {
    height:auto !important;
  }
</style>
<form method="post" asp-action="UpsertUser" enctype="multipart/form-data" class="profile-form">
  <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
  @if (TempData["ErrorMessage"] is not null)
  {
    <div class="alert alert-da">@TempData["ErrorMessage"]</div>
  }
  <div class="row">
    <!-- #region Profile Card -->
    <div class="col-xl-3 col-lg-4">
      <div class="clearfix">
        <div class="card card-bx profile-card author-profile m-b30">
          <div class="card-body">
            <div class="p-5">
              <div class="author-profile">
                <div class="author-media">
                  <img id="avatarPreview"
                       src="@(string.IsNullOrEmpty(Model.UserDetailDto.Avatar) ? "/images/default-avatar.png" : Model.UserDetailDto.Avatar)"
                       alt="آواتار کاربر"
                       style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%;">
                  <div class="upload-link" title="آپلود تصویر" data-toggle="tooltip" data-placement="right">
                    <input type="file"
                           class="update-flie"
                           id="avatarUpload"
                           name="AvatarFile"
                           accept="image/*">
                    <i class="fa fa-camera"></i>
                  </div>
                </div>
                <div class="author-info">
                  <h6 class="title">
                    @(string.IsNullOrEmpty(Model.UserDetailDto.FirstName) && string.IsNullOrEmpty(Model.UserDetailDto.LastName)
                                        ? "نام تنظیم نشده"
                                        : $"{Model.UserDetailDto.FirstName} {Model.UserDetailDto.LastName}")
                  </h6>
                  <span>@string.Join(", ", Model.UserDetailDto.RoleNames)</span>
                </div>
              </div>
              <!-- Error message for image validation -->
              <div id="avatarError" class="text-danger mt-2" style="display: none;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- #endregion -->
   

    <!-- #region User Form -->
    <div class="col-xl-9 col-lg-8">
      <div class="card profile-card card-bx m-b30">
        <div class="card-header">
          <h6 class="title">تنظیم حساب کاربری</h6>
        </div>

        <input type="hidden" asp-for="UserDetailDto.Id"/>
        <input type="hidden" asp-for="Mode"/>

        <div class="card-body">
          <div class="row">
            <!-- First Name -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">نام</label>
              <input type="text" class="form-control" asp-for="UserDetailDto.FirstName" placeholder="نام را وارد کنید">
              <span asp-validation-for="UserDetailDto.FirstName" class="text-danger"></span>
            </div>

            <!-- Last Name -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">نام خانوادگی</label>
              <input type="text" class="form-control" asp-for="UserDetailDto.LastName" placeholder="نام خانوادگی را وارد کنید">
              <span asp-validation-for="UserDetailDto.LastName" class="text-danger"></span>
            </div>
            <!-- Email -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">ایمیل</label>
              <input type="email" class="form-control" asp-for="UserDetailDto.Email" placeholder="example@gmail.com">
              <span asp-validation-for="UserDetailDto.Email" class="text-danger"></span>
            </div>

            <!-- User name -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">نام کاربری</label>
              <input type="text" class="form-control" asp-for="UserDetailDto.UserName"
                     placeholder="user_5235">
              <span asp-validation-for="UserDetailDto.Email" class="text-danger"></span>
            </div>
            <!-- Phone -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">تلفن</label>
              <input type="text" class="form-control" asp-for="UserDetailDto.PhoneNumber" placeholder="مثال: 09123456789">
              <span asp-validation-for="UserDetailDto.PhoneNumber" class="text-danger"></span>
            </div>



            <!-- Password (Admin reset only) -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">رمز عبور جدید</label>
              <input type="password" class="form-control" name="NewPassword" placeholder="****** (اختیاری)">
              <!-- No asp-for because password does NOT exist inside DTO -->
            </div>

            <!-- IsActive -->
            <div class="col-sm-6 m-b30">
              <label class="form-label">وضعیت کاربر</label>
              <select class="form-control" asp-for="UserDetailDto.IsActive">
                <option value="true">فعال</option>
                <option value="false">غیرفعال</option>
              </select>
            </div>
          </div>

          <!-- #region Roles -->
          <div class="card mt-4">
            <div class="card-header">
              <h4 class="card-title">انتخاب نقش های کاربر</h4>
            </div>

            <div class="card-body">
              <div class="row">

                @foreach (var role in Model.Roles.Items)
                {
                  var isChecked = Model.UserDetailDto.RoleNames.Contains(role.Name);
                  <div class="col-md-4 mb-2">
                    <div class="form-check">
                      <input type="checkbox"
                             class="form-check-input"
                             name="SelectedRoles"
                             value="@role.Id"
                             @(isChecked ? "checked" : "")/>

                      <label class="form-check-label">
                        @role.Name
                        <span class="text-muted">(@role.PermissionCount مجوز)</span>
                      </label>
                    </div>
                  </div>
                }

              </div>
            </div>
          </div>
          <!-- #endregion -->

        </div>

        <!-- Footer -->
        <div class="card-footer">
          <button class="btn btn-primary" type="submit">ذخیره تغییرات</button>
        </div>

      </div>
    </div>
  </div>

</form>
<!-- Add this script before closing body tag or in a separate JS file -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
      const avatarUpload = document.getElementById('avatarUpload');
      const avatarPreview = document.getElementById('avatarPreview');
      const avatarError = document.getElementById('avatarError');
      const maxSizeInBytes = 5 * 1024 * 1024; // 5 MB

      avatarUpload.addEventListener('change', function(e) {
          const file = e.target.files[0];

          // Clear previous error
          avatarError.style.display = 'none';
          avatarError.textContent = '';

          if (!file) {
              return;
          }

          // Check file type
          if (!file.type.startsWith('image/')) {
              avatarError.textContent = 'لطفاً فقط فایل تصویری انتخاب کنید.';
              avatarError.style.display = 'block';
              avatarUpload.value = '';
              return;
          }

          // Check file size (5 MB max)
          if (file.size > maxSizeInBytes) {
              avatarError.textContent = 'حجم تصویر نباید بیشتر از 5 مگابایت باشد.';
              avatarError.style.display = 'block';
              avatarUpload.value = '';
              return;
          }

          // Preview image
          const reader = new FileReader();
          reader.onload = function(event) {
              avatarPreview.src = event.target.result;
          };
          reader.readAsDataURL(file);
      });
  });
</script>
