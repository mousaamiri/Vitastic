@model Vitastic.Web.Models.ViewModels.UpsertSectionsViewModel
@{
  Layout = "";
}
@if (TempData["ErrorMessage"] is not null)
{
  <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
<div class="container-fluid py-4">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0">مدیریت سکشن‌ها و اپیزودها - @Model.CourseTitle</h5>
          <button type="button" class="btn btn-primary btn-sm"
                  id="addSectionBtn">
            <i class="fas fa-plus me-1"></i>
            افزودن سکشن
          </button>
        </div>

        <div class="card-body">
          <form asp-action="UpsertSections"
                asp-controller="CourseManager"
                asp-area="AdminPanel"
                method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CourseId"/>

            <div id="sectionsContainer">
              @if (Model.Sections.Any())
              {
                @for (int i = 0; i < Model.Sections.Count; i++)
                {
                  <partial name="_SectionItem" model="Model.Sections[i]"
                           view-data='new ViewDataDictionary(ViewData) { { "Index", i } }'/>
                }
              }
              else
              {
                <div class="alert alert-info text-center">
                  هنوز سکشنی اضافه نشده است. روی دکمه "افزودن سکشن" کلیک کنید.
                </div>
              }
            </div>

            <div class="mt-4 d-flex gap-2">
              <button type="submit"
                      class="btn btn-success">
                <i class="fas fa-save me-1"></i>
                ذخیره همه
              </button>
              <a onclick="DismissModal()"
                 href="javascript:void(0)"
                 class="btn btn-secondary">
                <i class="fas fa-arrow-right me-1"></i>
                بازگشت
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Message Box Modal - Material Design -->
<div class="modal fade" id="messageBoxModal" tabindex="-1" data-bs-backdrop="static">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
      <div class="modal-header bg-gradient-danger text-white border-0 py-3">
        <h5 class="modal-title fw-bold" id="messageBoxTitle">
          <i class="fas fa-exclamation-triangle me-2"></i>
          تایید عملیات
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <p id="messageBoxText" class="mb-0 text-center fs-6"></p>
      </div>
      <div class="modal-footer border-0 pt-0 pb-3 px-4">
        <button type="button" class="btn btn-light shadow-sm px-4" data-bs-dismiss="modal" id="messageBoxCancel">
          <i class="fas fa-times me-1"></i>
          خیر
        </button>
        <button type="button" class="btn btn-danger shadow-sm px-4" id="messageBoxConfirm">
          <i class="fas fa-check me-1"></i>
          بله
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Template برای سکشن جدید - Material Design -->
<template id="sectionTemplate">
  <div class="section-item mb-4">
    <div class="card border-0 shadow-sm"
         style="border-radius: 16px; overflow: hidden; border-right: 5px solid #0d6efd;">
      <div class="card-header bg-gradient-light d-flex justify-content-between align-items-center py-3 px-4">
        <div class="flex-grow-1 me-3">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px;">
              <i class="fas fa-folder text-primary"></i>
            </span>
            <input type="text"
                   name="Sections[INDEX].Title"
                   class="form-control border-start-0 shadow-sm"
                   style="border-radius: 0 10px 10px 0;"
                   placeholder="عنوان سکشن"
                   required/>
          </div>
          <input type="hidden" name="Sections[INDEX].DisplayOrder" value="DISPLAY_ORDER_VALUE"/>
        </div>
        <div class="btn-group shadow-sm">
          <button type="button" class="btn btn-danger remove-section-btn px-3">
            <i class="fas fa-trash me-1"></i>
            حذف
          </button>
          <button type="button" class="btn btn-success add-episode-btn px-3">
            <i class="fas fa-plus me-1"></i>
            اپیزود
          </button>
        </div>
      </div>
      <div class="card-body episodes-container p-4 bg-light">
        <div class="alert alert-secondary border-0 shadow-sm text-center mb-0" style="border-radius: 12px;">
          <i class="fas fa-film me-2"></i>
          هنوز اپیزودی اضافه نشده است.
        </div>
      </div>
    </div>
  </div>
</template>

<!-- Template برای اپیزود جدید (مخفی) -->
<template id="episodeTemplate">
  <div class="episode-item mb-3">
    <div class="card shadow-sm">
      <div class="card-body p-3">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <div class="form-floating">
              <input type="text"
                     name="Sections[SECTION_INDEX].Episodes[EPISODE_INDEX].Title"
                     class="form-control"
                     id="episodeTitle_EPISODE_INDEX"
                     placeholder="عنوان اپیزود"
                     required/>
              <label for="episodeTitle_EPISODE_INDEX">عنوان اپیزود</label>
            </div>
          </div>

          <div class="col-md-3">
            <label class="form-label text-muted small mb-1">
              <i class="fas fa-video me-1"></i>فایل ویدئو
            </label>
            <input type="file"
                   name="Sections[SECTION_INDEX].Episodes[EPISODE_INDEX].VideoFile"
                   class="form-control"
                   accept="video/mp4,video/webm,video/ogg,video/avi,video/mkv"
                   required/>
          </div>

          <div class="col-md-2">
            <div class="form-floating">
              <input type="number"
                     name="Sections[SECTION_INDEX].Episodes[EPISODE_INDEX].Price"
                     class="form-control"
                     id="episodePrice_EPISODE_INDEX"
                     placeholder="قیمت"
                     min="0"
                     value="0"
                     required/>
              <label for="episodePrice_EPISODE_INDEX">قیمت (تومان)</label>
            </div>
          </div>

          <div class="col-md-2">
            <div class="form-floating">
              <input type="number"
                     name="Sections[SECTION_INDEX].Episodes[EPISODE_INDEX].DisplayOrder"
                     class="form-control"
                     id="episodeDisplayOrder_EPISODE_INDEX"
                     value="EPISODE_DISPLAY_ORDER"
                     readonly/>
              <label for="episodeOrder_EPISODE_INDEX">ترتیب</label>
            </div>
          </div>

          <div class="col-md-2 text-end">
            <button type="button" class="btn btn-danger remove-episode-btn w-100">
              <i class="fas fa-trash-alt me-1"></i>حذف
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>



<style>
  .section-item {
    transition: all 0.3s ease;
  }

  .section-item:hover {
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  }

  .episodes-container:empty::after {
    content: 'هنوز اپیزودی اضافه نشده است.';
    display: block;
    text-align: center;
    color: #6c757d;
    padding: 1rem;
  }
</style>

<script>
  let sectionIndex = @Model.Sections.Count;
  const addSectionBtn = document.getElementById("addSectionBtn");

  if (addSectionBtn) {
    addSectionBtn.addEventListener("click", (e) => {
      AddNewSection(e);
    })
  }

  function AddNewSection() {
    console.log("📢 New section adding ... ")
    // hide alert (if exist )
    const alert = document.querySelector('#sectionsContainer .alert-info');
    if (alert) alert.remove();
    //  new section
    const sectionTemp = document.getElementById('sectionTemplate');
    const clone = sectionTemp.content.cloneNode(true);
    // add index
    const sectionHtml = clone.querySelector('.section-item');
    sectionHtml.innerHTML = sectionHtml.innerHTML
      .replace(/INDEX/g, sectionIndex)
      .replace(/DISPLAY_ORDER_VALUE/g, sectionIndex + 1);
    // add new section
    document.getElementById("sectionsContainer").appendChild(clone);
    sectionIndex++;
  }

  document.getElementById('sectionsContainer').addEventListener('click', async (e) => {
    if (e.target.closest('.remove-section-btn')) {
      const result = await ShowMessageBox(
        'حذف سکشن',
        'آیا از حذف این سکشن مطمئن هستید؟'
      );

      if (result) {
        DeleteSection(e);
      } else {
        console.log('عملیات لغو شد');
      }
    }
    if (e.target.closest('.add-episode-btn')) {
      AddNewEpisode(e);
    }
    if (e.target.closest('.remove-episode-btn')) {
      const result = await ShowMessageBox(
        'حذف اپیزود',
        'آیا از حذف این اپیزود مطمئن هستید؟'
      );

      if (result) {
        DeleteEpisode(e);
      } else {
        console.log('عملیات لغو شد');
      }
    }
  })

  function DeleteSection(e) {
    console.log("📢 Deleting section ... ")
    const sectionItem = e.target.closest(".section-item");
    if (sectionItem) sectionItem.remove();

    const remainingSections = document.querySelectorAll('.section-item').length;
    if (remainingSections === 0) {
      document.getElementById("sectionsContainer").innerHTML =
        ` <div class="alert alert-info text-center">
                        هنوز سکشنی اضافه نشده است. روی دکمه "افزودن سکشن" کلیک کنید.
          </div>
        `;
    }

  }

  function AddNewEpisode(e) {
    console.log("📢 New episode adding ... ")
    // section that clicked
    const sectionItem = e.target.closest('.section-item');
    const episodeContainer = sectionItem.querySelector('.episodes-container');
    // remove alert if exist
    const alert = episodeContainer.querySelector('.alert-secondary');
    if (alert) alert.remove();
    // find section index from name attribute
    const sectionInput = sectionItem.querySelector('input[name*="Sections["]');
    const sectionIndexMatch = sectionInput.name.match(/Sections\[(\d+)\]/);
    const currentSectionIndex = sectionIndexMatch ? sectionIndexMatch[1] : 0;
    // find episode count
    const existingEpisodes = episodeContainer.querySelectorAll('.episode-item').length;
    // new episode
    const episodeTemp = document.getElementById('episodeTemplate');
    const clone = episodeTemp.content.cloneNode(true);
    // replace SECTION_INDEX & EPISODE_INDEX
    const episodeHtml = clone.querySelector('.episode-item');
    episodeHtml.innerHTML = episodeHtml.innerHTML
      .replace(/SECTION_INDEX/g, currentSectionIndex)
      .replace(/EPISODE_INDEX/g, existingEpisodes)
      .replace(/EPISODE_DISPLAY_ORDER/g, existingEpisodes + 1);
    // add event listener for video input -> to get duration
    const videoInput = episodeHtml.querySelector('input[type="file"]');
    if (videoInput) {
      videoInput.addEventListener('change', (e) => {
        HandleVideoSelection(event, episodeHtml, currentSectionIndex, existingEpisodes);
      });
    }
    // add new episode
    episodeContainer.appendChild(clone);
  }

  function HandleVideoSelection(event, episodeHtml, sectionIndex, episodeIndex) {
    const file = event.target.files[0];
    if (!file) return;

    const video = document.createElement('video');
    video.preload = 'metadata';

    video.onloadedmetadata = function () {
      window.URL.revokeObjectURL(video.src);
      const durationSeconds = Math.round(video.duration);

      console.log(`📹 مدت زمان ویدئو: ${durationSeconds} ثانیه`);

      // ⭐ add hidden input to for save duration
      let durationInput = episodeHtml.querySelector(`input[name="Sections[${sectionIndex}].Episodes[${episodeIndex}].DurationSeconds"]`);
      if (!durationInput) {
        durationInput = document.createElement('input');
        durationInput.type = 'hidden';
        durationInput.name = `Sections[${sectionIndex}].Episodes[${episodeIndex}].DurationSeconds`;
        episodeHtml.appendChild(durationInput);
      }
      durationInput.value = durationSeconds;
    };

    video.onerror = function () {
      console.error('❌ خطا در خواندن فایل ویدئو');
      ShowMessageBox('خطا', 'فایل انتخاب شده معتبر نیست یا قابل خواندن نمی‌باشد.');
    };

    video.src = URL.createObjectURL(file);
  }

  function DeleteEpisode(e) {
    console.log("📢 Delete episode ... ")
    // episode that clicked
    const episodeItem = e.target.closest('.episode-item');
    const sectionItem = e.target.closest('.section-item');
    const episodeContainer = sectionItem.querySelector('.episodes-container');
    // delete episode
    episodeItem.remove();
    // show alert if container is empty
    const remainingEpisodes = episodeContainer.querySelectorAll('.episode-item').length;
    if (remainingEpisodes === 0) {
      const alert = document.createElement('div');
      alert.className = 'alert alert-secondary text-center mb-0';
      alert.textContent = 'هنوز اپیزودی اضافه نشده است.';
      episodeContainer.appendChild(alert);
    }
  }

  function ShowMessageBox(title, message) {
    return new Promise((resolve, reject) => {
      const modal = new bootstrap.Modal(document.getElementById('messageBoxModal'));
      // setup content
      document.getElementById('messageBoxTitle').textContent = title;
      document.getElementById('messageBoxText').textContent = message;
      // buttons
      const confirmBtn = document.querySelector('#messageBoxConfirm');
      const cancelBtn = document.querySelector('#messageBoxCancel');
      /// remove previous events
      const newConfirmBtn = confirmBtn.cloneNode(true);
      const newCancelBtn = cancelBtn.cloneNode(true);
      confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
      cancelBtn.parentNode.replaceChild(newCancelBtn, cancelBtn);
      // add event listeners
      newConfirmBtn.addEventListener('click', (e) => {
        modal.hide();
        resolve(true);
      });
      newCancelBtn.addEventListener('click', (e) => {
        modal.hide();
        resolve(false);
      });
      //show modal
      modal.show();
    })
  }

  function DismissModal() {
    const result = ShowMessageBox("بستن پنجره ویرایش سکشن ها", "آیا از بستن این پنجره اطمینان دارید؟ تمام تغییرات شما از بین خواهند رفت!!!");
    if (result) {
      // dismiss this modal

    }
  }

  document.querySelector('form').addEventListener('submit', async function (e) {
    e.preventDefault();
    await SubmitForm(this);
  });

  async function SubmitForm(form) {
    const formData = new FormData(form);
    // submit button change state
    const submitButton = form.querySelector('button[type="submit"]');
    const originalText = submitButton.innerHTML;
    submitButton.disabled = true;
    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>در حال ارسال...';
    try {
      debugger
      const response =await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
        }
      });
      if (response.ok) {
        const result = response.json();
        //show success message
       await ShowMessageBox(
          'موفقیت',
          'اطلاعات با موفقیت ذخیره شد!'
        );
        setTimeout(function () {
          window.location.reload();
        }, 1000)
      } else {
        const errorData = await response.json().catch(() => null);
        const errorMessage = errorData?.message || errorData?.title || 'خطا در ارسال اطلاعات';
        throw new Error(errorMessage);
      }

    } catch (error) {
      console.error('Error:', error);
      await ShowMessageBox(
        'خطا',
        error.message || 'خطایی در ارسال اطلاعات رخ داد. لطفا دوباره تلاش کنید.'
      );
    } finally {
      submitButton.disabled = false;
      submitButton.innerHTML = originalText;
    }


  }
</script>
