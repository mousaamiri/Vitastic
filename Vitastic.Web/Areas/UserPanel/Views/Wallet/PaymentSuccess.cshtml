@* @model Vitastic.Core.Dtos.Payment.PaymentVerificationResult *@

@{
    ViewBag.Title = Model.Success ? "پرداخت موفق" : "پرداخت ناموفق";
    Layout = "";
}

<html>
<head>
    <!-- Core CSS -->
    <link rel="stylesheet" href="/admin-assets/assets/vendor/css/rtl/core.css" class="template-customizer-core-css" />
    <link rel="stylesheet" href="/admin-assets/assets/vendor/css/rtl/theme-bordered-dark.css" class="template-customizer-core-css" />
</head>
<style>
    body {
        font-family: inherit;
        width: 100%;
        height: 100vh;
        align-content: center;
        direction: rtl;
        text-align: center;
        padding: 40px 0;
        background: #EBF0F5;
    }
    h1 {
        font-weight: 900;
        font-size: 40px;
        margin-bottom: 10px;
    }
    p {
        color: #404F5E;
        font-size:20px;
        margin: 5px 0;
    }
    i {
        font-size: 100px;
        line-height: 200px;
        margin-left:-15px;
    }
    .card {
        background: white;
        padding: 60px;
        border-radius: 4px;
        box-shadow: 0 2px 3px #C8D0D8;
        display: inline-block;
        margin: 0 auto;
    }
    .success i { color: #4bb061; }
    .failure i { color: #FF6F61; }

    .btn-back {
        display: inline-block;
        margin-top: 30px;
        padding: 12px 25px;
        font-size: 18px;
        font-weight: 600;
        color: white;
        background-color: #4bb061;
        border-radius: 5px;
        text-decoration: none;
        transition: background-color 0.3s;
    }
    .btn-back:hover {
        background-color: #3a8c4a;
        color: whitesmoke;
    }
</style>
<body>
<div class="card @(Model.Success ? "success" : "failure")">
    <div style="border-radius:200px; height:200px; width:200px; background: @(Model.Success ? "#F8FAF5" : "#FDEDEC"); margin:0 auto;">
        <i class="@(Model.Success ? "checkmark" : "crossmark")">@(Model.Success ? "✓" : "✕")</i>
    </div>

    <h1>@(Model.Success ? "پرداخت موفقیت‌آمیز" : "پرداخت ناموفق")</h1> 

    <p>
        مبلغ: @Model.Amount.ToString("N0") تومان
    </p>

    @if (Model.Success && !string.IsNullOrEmpty(Model.RefId))
    {
        <p>
            شناسه تراکنش: <strong>@Model.RefId</strong>
        </p>
    }

    @if (!Model.Success && !string.IsNullOrEmpty(Model.Message))
    {
        <p>
            دلیل: @Model.Message
        </p>
    }

    <p>
        متشکریم که از خدمات ما استفاده کردید.
    </p>

    <a href="@Url.Action("Index", "Wallet")" class="btn-back">
        بازگشت به پنل کاربری
    </a>
</div>
</body>
</html>
