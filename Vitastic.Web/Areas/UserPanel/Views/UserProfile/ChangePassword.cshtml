@model Vitastic.Web.Models.DTOs.UserProfile.ChangePasswordDto

<div class="row">
  <div class="col-12">
    <div class="row">
      <div class="col-xl-12">
        <div class="card">
          <div class="card-body profile-accordion pb-0">
            <div class="accordion" id="accordionPassword">
              <div class="accordion-item">
                <h2 class="accordion-header" id="headingPassword">
                  <button class="accordion-button border-0" type="button" data-bs-toggle="collapse"
                          data-bs-target="#collapsePassword" aria-expanded="true" aria-controls="collapsePassword">
                    تغییر رمز عبور
                  </button>
                </h2>
                <div id="collapsePassword" class="accordion-collapse collapse show"
                     aria-labelledby="headingPassword" data-bs-parent="#accordionPassword">
                  <div class="accordion-body">

                    @if (TempData["IsCritical"] != null && (bool)TempData["IsCritical"])
                    {
                      <div class="alert alert-success text-center mb-4" role="alert">
                        @TempData["Message"]
                        <br />
                        <span id="logoutCounter">5</span> ثانیه دیگر به صفحه خروج هدایت می‌شوید...
                      </div>
                      <script>
                        document.addEventListener('DOMContentLoaded', () => {
                          let counter = 5;
                          const counterElement = document.getElementById("logoutCounter");
                          const logoutUrl = '@Url.Action("Logout", "Account",new{area=""})'; // URL داینامیک از کنترلر Auth

                          const interval = setInterval(() => {
                            counter--;
                            if (counterElement) counterElement.textContent = counter;
                            if (counter <= 0) {
                              clearInterval(interval);
                              window.location.href = logoutUrl; // استفاده از URL داینامیک
                            }
                          }, 1000);
                        });
                      </script>

                    }

                    <form id="formChangePassword" asp-action="ChangePassword" method="post">
                      @Html.AntiForgeryToken()
                      <div asp-validation-summary="All" class="alert alert-danger mb-4" role="alert"></div>

                      <div class="row mb-3">
                        <div class="col-md-12">
                          <div class="form-floating form-floating-outline input-group input-group-merge">
                            <input asp-for="CurrentPassword" class="form-control" type="password" id="oldPassword" placeholder="············">
                            <label for="oldPassword">رمز عبور فعلی</label>
                            <span class="input-group-text cursor-pointer toggle-eye"><i class="mdi mdi-eye-off-outline"></i></span>
                          </div>
                          <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>
                      </div>

                      <div class="row mb-3">
                        <div class="col-md-6">
                          <div class="form-floating form-floating-outline input-group input-group-merge">
                            <input asp-for="NewPassword" class="form-control" type="password" id="newPassword" placeholder="············">
                            <label for="newPassword">رمز عبور جدید</label>
                            <span class="input-group-text cursor-pointer toggle-eye"><i class="mdi mdi-eye-off-outline"></i></span>
                          </div>
                          <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                          <div class="form-floating form-floating-outline input-group input-group-merge">
                            <input asp-for="ConfirmPassword" class="form-control" type="password" id="confirmPassword" placeholder="············">
                            <label for="confirmPassword">تأیید رمز عبور</label>
                            <span class="input-group-text cursor-pointer toggle-eye"><i class="mdi mdi-eye-off-outline"></i></span>
                          </div>
                          <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                      </div>

                      <h6 class="text-body mb-2">الزامات رمز عبور:</h6>
                      <ul class="ps-3 mb-4">
                        <li id="oldPasswordStatus">رمز عبور فعلی: حداقل ۶ کاراکتر</li>
                        <hr style="border-top:1px solid #ccc; margin:5px 0;">
                        <li id="lengthReq">حداقل ۶ کاراکتر</li>
                        <li id="lowerReq">حداقل یک حرف کوچک (a-z)</li>
                        <li id="upperReq">حداقل یک حرف بزرگ (A-Z)</li>
                        <li id="numberReq">حداقل یک عدد (۰-۹)</li>
                        <li id="symbolReq">حداقل یک نماد (مثل !@@#$%^&* یا فاصله)</li>
                        <hr style="border-top:1px solid #ccc; margin:5px 0;">
                        <li id="confirmPasswordStatus">تکرار رمز عبور: باید با رمز جدید یکسان باشد</li>
                      </ul>

                      <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="submitBtn" disabled>ذخیره تغییرات</button>
                        <button type="reset" class="btn btn-outline-secondary">لغو</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section AdditionalScript {
  <script>
    // Toggle password visibility
    document.querySelectorAll('.toggle-eye').forEach(span => {
      span.addEventListener('click', function() {
        const input = this.closest('.input-group').querySelector('input');
        const icon = this.querySelector('i');
        if (input.type === 'password') {
          input.type = 'text';
          icon.classList.replace('mdi-eye-off-outline', 'mdi-eye-outline');
        } else {
          input.type = 'password';
          icon.classList.replace('mdi-eye-outline', 'mdi-eye-off-outline');
        }
      });
    });

    // DOM elements
    const oldPasswordInput = document.getElementById('oldPassword');
    const newPasswordInput = document.getElementById('newPassword');
    const confirmPasswordInput = document.getElementById('confirmPassword');
    const submitBtn = document.getElementById('submitBtn');

    const oldStatus = document.getElementById('oldPasswordStatus');
    const confirmStatus = document.getElementById('confirmPasswordStatus');
    const lengthReq = document.getElementById('lengthReq');
    const lowerReq = document.getElementById('lowerReq');
    const upperReq = document.getElementById('upperReq');
    const numberReq = document.getElementById('numberReq');
    const symbolReq = document.getElementById('symbolReq');

    // Validate new password strength
    function validateNewPassword(password) {
      return {
        length: /.{6,}/.test(password),
        lower: /[a-z]/.test(password),
        upper: /[A-Z]/.test(password),
        number: /\d/.test(password),
        symbol: /[!@@#\$%\^&*\s]/.test(password)
      };
    }

    // Update UI based on validation
    function updateRequirementsDisplay(password) {
      const checks = validateNewPassword(password);
      lengthReq.style.color = checks.length ? 'green' : 'orange';
      lowerReq.style.color = checks.lower ? 'green' : 'orange';
      upperReq.style.color = checks.upper ? 'green' : 'orange';
      numberReq.style.color = checks.number ? 'green' : 'orange';
      symbolReq.style.color = checks.symbol ? 'green' : 'orange';
    }

    // Check overall form validity
    function checkFormValidity() {
      const oldValid = oldPasswordInput.value.length >= 6;
      const newChecks = validateNewPassword(newPasswordInput.value);
      const newValid = Object.values(newChecks).every(v => v);
      const confirmMatch = newPasswordInput.value === confirmPasswordInput.value && newPasswordInput.value.trim() !== '';

      oldStatus.style.color = oldValid ? 'green' : 'orange';
      confirmStatus.style.color = confirmMatch ? 'green' : 'orange';
      updateRequirementsDisplay(newPasswordInput.value);

      submitBtn.disabled = !(oldValid && newValid && confirmMatch);
    }

    // Attach event listeners
    [oldPasswordInput, newPasswordInput, confirmPasswordInput].forEach(input => {
      input.addEventListener('input', checkFormValidity);
    });

    // Optional: Prevent form submission if invalid (though server-side validation is primary)
    document.getElementById('formChangePassword')?.addEventListener('submit', function(e) {
      if (submitBtn.disabled) {
        e.preventDefault();
        alert('لطفاً تمام شرایط رمز عبور را رعایت کنید.');
      }
    });
  </script>
}
